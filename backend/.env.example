# Coolify: set these in the application Environment Variables (no .env file in container).
# In .NET, config keys use __ for nesting: ConnectionStrings__DefaultConnection → ConnectionStrings:DefaultConnection

# Required: PostgreSQL connection string (Coolify DB or external)
ConnectionStrings__DefaultConnection=Host=;Database=;Username=;Password=

# Required: JWT (key must be 32+ chars for HS256)
Jwt__Key=
Jwt__Issuer=Studyzone.Api
Jwt__Audience=Studyzone.App

# Required: CORS allowed origins (semicolon-separated; e.g. your frontend URL)
CORS__Origins=

# Optional: seed admin user only on first run when DB has no users
# Seed__AdminUserId=
# Seed__AdminPassword=
# Seed__AdminName=

# Optional: MinIO for file storage (admission form images, documents). If set, MinIO is used instead of local disk.
# MinIO__Endpoint=https://minio.example.com
# MinIO__Bucket=studyzone
# MinIO__AccessKey=
# MinIO__SecretKey=
