# Copy to .env and set values. Load with your shell or use export (Linux/macOS) / set (Windows).
# In .NET, config keys use __ for nesting: ConnectionStrings__DefaultConnection → ConnectionStrings:DefaultConnection

# Required: PostgreSQL connection string
ConnectionStrings__DefaultConnection=Host=localhost;Database=studyzone;Username=postgres;Password=123456qw

# Required: JWT (key must be 32+ chars for HS256)
Jwt__Key=YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG
Jwt__Issuer=Studyzone.Api
Jwt__Audience=Studyzone.App

# Required: CORS allowed origins (semicolon-separated)
CORS__Origins=http://localhost:5173;http://localhost:8080

# Optional: seed admin user only on first run when DB has no users
Seed__AdminUserId=admin
Seed__AdminPassword=admin
Seed__AdminName=Admin

# Optional: MinIO for file storage (admission form images). If set, uploads go to MinIO instead of local disk.
MinIO__Endpoint=https://minio-vc8kcccosc8gkkwogw00scsc.187.77.191.143.sslip.io
MinIO__Bucket=studyzone
MinIO__AccessKey=oU4kn57wPZA6m4yi
MinIO__SecretKey=Qzmrn1oexC62H0ZNKxrcxq5Vze08IK4P
